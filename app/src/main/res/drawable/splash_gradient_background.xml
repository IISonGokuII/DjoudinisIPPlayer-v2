<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Radial gradient background for cinematic look -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:centerX="50%"
                android:centerY="40%"
                android:gradientRadius="80%"
                android:startColor="#1a237e"
                android:centerColor="#0d1642"
                android:endColor="#000000"
                android:angle="270" />
        </shape>
    </item>
</layer-list>
