<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Circular background with gradient for the logo -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#3949ab"
                android:centerColor="#1a237e"
                android:endColor="#0d1642" />
            <size
                android:width="160dp"
                android:height="160dp" />
        </shape>
    </item>
    <!-- Inner glow effect -->
    <item
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="70%"
                android:centerX="30%"
                android:centerY="30%"
                android:startColor="#5c6bc0"
                android:endColor="#1a237e" />
        </shape>
    </item>
</layer-list>
